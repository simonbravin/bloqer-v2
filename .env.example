# ─────────────────────────────────────────────────────────────────────────────
# Bloqer 2.0 — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Database (PostgreSQL / Neon) ─────────────────────────────────────────────
# Required before any DB operation (Phase 1+)
DATABASE_URL=
DIRECT_URL=

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
# AUTH_SECRET: required. Generate with: openssl rand -base64 32
AUTH_SECRET=
# AUTH_URL: optional in dev (auto-detected). Set in production.
# AUTH_URL=https://your-domain.com
# Public base URL for emails / invitations (first valid wins with AUTH_URL):
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# APP_URL=https://your-domain.com
# Google OAuth: create at console.cloud.google.com
# Optional for local dev (app boots but OAuth login fails without them)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional for app boot — both required together to send mail (see isEmailConfigured()).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Optional for app boot — all non-empty R2_* (except optional R2_PUBLIC_URL) required for uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Cron (operational alerts) ────────────────────────────────────────────────
# Min 16 chars. If unset/short, /api/cron/operational-alerts returns 503.
CRON_SECRET=

# ── Platform superadmin allowlist (optional) ─────────────────────────────────
# Comma-separated emails; see docs/bloqer2.0/08-architecture/PLATFORM_SUPERADMIN_ARCHITECTURE.md
PLATFORM_SUPERADMIN_EMAILS=

# ── Seed (db:seed only; not required for app runtime) ─────────────────────────
# SEED_USER_EMAIL=you@example.com
