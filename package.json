{
  "name": "bloqer-v2",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm ci:prisma && turbo build",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @bloqer/database exec prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @bloqer/database exec prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env -- pnpm --filter @bloqer/database exec prisma migrate deploy",
    "db:migrate:status": "dotenv -e .env -- pnpm --filter @bloqer/database exec prisma migrate status",
    "db:seed": "dotenv -e .env -- pnpm --filter @bloqer/database db:seed",
    "ci:prisma": "pnpm --filter @bloqer/database exec prisma generate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
