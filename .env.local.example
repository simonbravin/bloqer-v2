# ─────────────────────────────────────────────────────────────────────────────
# Bloqer 2.0 — Local Development Overrides
# This file is gitignored. Safe to put real local values here.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Use a Neon branch or local Postgres for development.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# AUTH_URL not needed in local dev (auto-detected as http://localhost:3000)
# Google OAuth from console.cloud.google.com — optional for local dev
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=dev@yourdomain.com

# ── Storage ───────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bloqer-dev
R2_PUBLIC_URL=
